# DC Motor Control System Configuration
# Copy this file to .env and adjust values as needed

# GPIO Pin Configuration (Raspberry Pi)
GPIO_MOTOR_IN1=17
GPIO_MOTOR_IN2=18
GPIO_MOTOR_ENA=12
GPIO_IR_SENSOR=23
GPIO_IR_SENSOR_2=24

# Motor Hardware Configuration
MOTOR_MAX_RPM=100
MOTOR_PULSES_PER_REV=1
MOTOR_PWM_FREQ=1000
MOTOR_MIN_PULSE_WIDTH=1.0

# PI Controller Parameters
CONTROLLER_PI_KP=0.5
CONTROLLER_PI_KI=0.1

# PID Controller Parameters
CONTROLLER_PID_KP=0.6
CONTROLLER_PID_KI=0.15
CONTROLLER_PID_KD=0.05

# Application Paths
APP_BASE_DIR=.
APP_MODELS_DIR=./models
APP_LOGS_DIR=./logs
APP_DATA_DIR=./data

# GUI Configuration
GUI_WINDOW_WIDTH=1200
GUI_WINDOW_HEIGHT=800
GUI_PLOT_UPDATE_MS=100
GUI_THEME=modern

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
